  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7A849D",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#9D6500"
      }
    },
    {
      "name": "Types",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#8A5A00"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "support.function",
        "variable.function"
      ],
      "settings": {
        "foreground": "#B56F00"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "meta.object-literal.key",
        "support.variable"
      ],
      "settings": {
        "foreground": "#25324B"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#8F5C2E"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant",
        "variable.other.constant",
        "constant.language"
      ],
      "settings": {
        "foreground": "#B05A22"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#A3472B"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#9D5C2A"
      }
    },
    {
      "name": "String Escape",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#A96A2D"
      }
    },
    {
      "name": "Operators and punctuation",
      "scope": [
        "keyword.operator",
        "punctuation",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#596681"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#B05A22"
      }
    },
    {
      "name": "Tag attributes",
      "scope": [
        "entity.other.attribute-name",
        "meta.attribute"
      ],
      "settings": {
        "foreground": "#9D6500"
      }
    },
    {
      "name": "Markdown headings",
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#A56A00",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#9D6500",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#A96A2D",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code"
      ],
      "settings": {
        "foreground": "#8A5A00"
      }
    },
    {
      "name": "JSON keys",
      "scope": [
        "source.json meta.structure.dictionary.json support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#9D6500"
      }
    },
    {
      "name": "JSON values",
      "scope": [
        "source.json meta.structure.dictionary.json string.quoted.double.json",
        "source.json meta.structure.dictionary.json constant.language.json"
      ],
      "settings": {
        "foreground": "#9D5C2A"
      }
    },
    {
      "name": "YAML/TOML keys",
      "scope": [
        "source.yaml entity.name.tag",
        "source.toml key.unquoted"
      ],
      "settings": {
        "foreground": "#9D6500"
      }
    },
    {
      "name": "YAML/TOML values",
      "scope": [
        "source.yaml string.unquoted",
        "source.toml string.quoted"
      ],
      "settings": {
        "foreground": "#9D5C2A"
      }
    },
    {
      "name": "Diff inserted",
      "scope": [
        "markup.inserted",
        "meta.diff.header.from-file"
      ],
      "settings": {
        "foreground": "#3B8956"
      }
    },
    {
      "name": "Diff removed",
      "scope": [
        "markup.deleted",
        "meta.diff.header.to-file"
      ],
      "settings": {
        "foreground": "#B14D46"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FCFDFF",
        "background": "#B14D46"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#8A5A00",
    "class": "#8A5A00",
    "enum": "#9D6500",
    "interface": "#8A5A00",
    "struct": "#8A5A00",
    "typeParameter": "#9D6500",
    "type": "#8A5A00",
    "parameter": "#8F5C2E",
    "variable": "#25324B",
    "property": "#25324B",
    "enumMember": "#B05A22",
    "event": "#B05A22",
    "function": "#B56F00",
    "method": "#B56F00",
    "macro": "#B05A22",
    "keyword": "#9D6500",
    "modifier": "#9D6500",
