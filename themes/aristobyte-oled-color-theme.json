    "symbolIcon.objectForeground": "#FFD96A",
    "symbolIcon.operatorForeground": "#B6C0E0",
    "symbolIcon.packageForeground": "#FFD96A",
    "symbolIcon.propertyForeground": "#F2F5FF",
    "symbolIcon.referenceForeground": "#FFEE27",
    "symbolIcon.snippetForeground": "#F3A85D",
    "symbolIcon.stringForeground": "#F3A85D",
    "symbolIcon.structForeground": "#FFD96A",
    "symbolIcon.textForeground": "#CFD6EA",
    "symbolIcon.typeParameterForeground": "#FEC800",
    "symbolIcon.unitForeground": "#F18E35",
    "symbolIcon.variableForeground": "#F2F5FF"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6F7A9D",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#FEC800"
      }
    },
    {
      "name": "Types",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#FFD96A"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "support.function",
        "variable.function"
      ],
      "settings": {
        "foreground": "#FFEE27"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "meta.object-literal.key",
        "support.variable"
      ],
      "settings": {
        "foreground": "#F2F5FF"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#F7CB94"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant",
        "variable.other.constant",
        "constant.language"
      ],
      "settings": {
        "foreground": "#F18E35"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#E95F32"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#F3A85D"
      }
    },
    {
      "name": "String Escape",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#FFCF8A"
      }
    },
    {
      "name": "Operators and punctuation",
      "scope": [
        "keyword.operator",
        "punctuation",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#B6C0E0"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#F18E35"
      }
    },
    {
      "name": "Tag attributes",
      "scope": [
        "entity.other.attribute-name",
        "meta.attribute"
      ],
      "settings": {
        "foreground": "#FEC800"
      }
    },
    {
      "name": "Markdown headings",
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#FFEE27",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#FEC800",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#F3A85D",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code"
      ],
      "settings": {
        "foreground": "#FFD96A"
      }
    },
    {
      "name": "JSON keys",
      "scope": [
        "source.json meta.structure.dictionary.json support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#FFEE27"
      }
    },
    {
      "name": "JSON values",
      "scope": [
        "source.json meta.structure.dictionary.json string.quoted.double.json",
        "source.json meta.structure.dictionary.json constant.language.json"
      ],
      "settings": {
        "foreground": "#F3A85D"
      }
    },
    {
      "name": "YAML/TOML keys",
      "scope": [
        "source.yaml entity.name.tag",
        "source.toml key.unquoted"
      ],
      "settings": {
        "foreground": "#FFEE27"
      }
    },
    {
      "name": "YAML/TOML values",
      "scope": [
        "source.yaml string.unquoted",
        "source.toml string.quoted"
      ],
      "settings": {
        "foreground": "#F3A85D"
      }
    },
    {
      "name": "Diff inserted",
      "scope": [
        "markup.inserted",
        "meta.diff.header.from-file"
      ],
      "settings": {
        "foreground": "#7BC580"
      }
    },
    {
      "name": "Diff removed",
      "scope": [
        "markup.deleted",
        "meta.diff.header.to-file"
      ],
      "settings": {
        "foreground": "#E2312D"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FFFFFF",
        "background": "#E2312D"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#FFD96A",
    "class": "#FFD96A",
    "enum": "#FEC800",
    "interface": "#FFD96A",
    "struct": "#FFD96A",
    "typeParameter": "#FEC800",
    "type": "#FFD96A",
    "parameter": "#F7CB94",
    "variable": "#F2F5FF",
    "property": "#F2F5FF",
    "enumMember": "#F18E35",
    "event": "#F18E35",
    "function": "#FFEE27",
    "method": "#FFEE27",
    "macro": "#F18E35",
