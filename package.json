{
  "name": "aristo-theme-vscode-color-theme",
  "displayName": "AristoTheme - AristoByte Color Theme",
  "description": "A modern, sleek VS Code theme designed for developers who value clarity and productivity. AristoByte Theme combines a tech-forward color palette with high-contrast syntax highlighting, optimized for long coding sessions and deep focus.",
  "version": "1.2.1",
  "publisher": "aristobyte",
  "author": {
    "name": "AristoByte Team",
    "url": "https://github.com/aristobyte"
  },
  "homepage": "https://aristobyte.com",
  "preview": false,
  "qna": "https://github.com/aristobyte/aristo-theme-vscode-extension/discussions",
  "sponsor": {
    "url": "https://github.com/sponsors/aristobyte-team"
  },
  "engines": {
    "vscode": ">=1.90.0"
  },
  "galleryBanner": {
    "color": "#0E1220",
    "theme": "dark"
  },
  "categories": [
    "Themes"
  ],
  "badges": [
    {
      "url": "https://img.shields.io/visual-studio-marketplace/v/aristobyte.aristo-theme-vscode-color-theme?label=VS%20Marketplace",
      "href": "https://marketplace.visualstudio.com/items?itemName=aristobyte.aristo-theme-vscode-color-theme",
      "description": "VS Code Marketplace version"
    },
    {
      "url": "https://img.shields.io/open-vsx/v/aristobyte/aristo-theme-vscode-color-theme?label=Open%20VSX",
      "href": "https://open-vsx.org/extension/aristobyte/aristo-theme-vscode-color-theme",
      "description": "Open VSX version"
    }
  ],
  "files": [
    "themes/*.json",
    "docs/**",
    "assets/**",
    "ui/**",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "extension.js"
  ],
  "scripts": {
    "package": "@vscode/vsce package",
    "package:pre": "@vscode/vsce package --pre-release",
    "install:local": "code --install-extension $(ls -t *.vsix | head -n 1) --force",
    "dev": "yarn package && yarn install:local",
    "publish:marketplace": "@vscode/vsce publish",
    "publish:ovsx": "ovsx publish",
    "release:patch": "yarn bump:patch",
    "release:minor": "yarn bump:minor",
    "release:major": "yarn bump:major",
    "clean:vsix": "rm -f *.vsix",
    "uninstall:local": "code --uninstall-extension aristobyte.aristo-theme-vscode-color-theme",
    "reinstall:local": "yarn uninstall:local || true && yarn dev",
    "publish:marketplace:token": "@vscode/vsce publish -p \"$VSCE_PAT\"",
    "publish:ovsx:token": "ovsx publish -p \"$OVSX_PAT\"",
    "bump:detect": "scripts/detect-bump.sh",
    "bump:auto": "scripts/bump.sh",
    "bump:patch": "scripts/bump.sh patch",
    "bump:minor": "scripts/bump.sh minor",
    "bump:major": "scripts/bump.sh major",
    "build:release": "scripts/build.sh",
    "publish:release": "scripts/publish.sh",
    "release:create": "scripts/create-github-release.sh",
    "release:upload-assets": "scripts/upload-release-assets.sh"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aristobyte/aristo-theme-vscode-extension"
  },
  "bugs": {
    "url": "https://github.com/aristobyte/aristo-theme-vscode-extension/issues"
  },
  "icon": "assets/logo.png",
  "keywords": [
    "aristobyte",
    "aristobyte-theme",
    "theme",
    "dark",
    "light",
    "vscode",
    "vscode-theme",
    "vscode-color-theme",
    "developer",
    "modern",
    "programming",
    "color-theme",
    "syntax-highlighting",
    "accessibility",
    "productivity",
    "high-contrast",
    "developer-experience",
    "editor-theme",
    "ui-theme",
    "minimal",
    "minimalistic",
    "branded-theme",
    "dark-theme",
    "light-theme"
  ],
  "license": "MIT",
  "devDependencies": {
    "@vscode/vsce": "^3.6.2",
    "ovsx": "^0.10.3"
  },
  "contributes": {
    "themes": [
      {
        "label": "AristoByte Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/aristobyte-dark-color-theme.json"
      },
      {
        "label": "AristoByte Midnight",
        "uiTheme": "vs-dark",
        "path": "./themes/aristobyte-midnight-color-theme.json"
      },
      {
        "label": "AristoByte Dusk",
        "uiTheme": "vs-dark",
        "path": "./themes/aristobyte-dusk-color-theme.json"
      },
      {
        "label": "AristoByte High Contrast Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/aristobyte-high-contrast-dark-color-theme.json"
      },
      {
        "label": "AristoByte OLED",
        "uiTheme": "vs-dark",
        "path": "./themes/aristobyte-oled-color-theme.json"
      },
      {
        "label": "AristoByte Light",
        "uiTheme": "vs",
        "path": "./themes/aristobyte-light-color-theme.json"
      },
      {
        "label": "AristoByte Soft Light",
        "uiTheme": "vs",
        "path": "./themes/aristobyte-soft-light-color-theme.json"
      },
      {
        "label": "AristoByte High Contrast Light",
        "uiTheme": "vs",
        "path": "./themes/aristobyte-high-contrast-light-color-theme.json"
      }
    ],
    "walkthroughs": [
      {
        "id": "aristobyte.getting-started",
        "title": "AristoByte Dashboard",
        "description": "A complete in-editor onboarding hub for installing, using, customizing, and troubleshooting AristoByte.",
        "steps": [
          {
            "id": "aristobyte.overview",
            "title": "Overview Tab",
            "description": "Start with the overview in [`docs/OVERVIEW.md`](https://github.com/aristobyte/aristo-theme-vscode-extension/blob/master/docs/OVERVIEW.md).",
            "media": {
              "image": "assets/dashboard-tab-overview.png",
              "altText": "AristoByte dashboard overview tab"
            }
          },
          {
            "id": "aristobyte.installation",
            "title": "Installation Tab",
            "description": "Follow install options in [`docs/INSTALLATION.md`](https://github.com/aristobyte/aristo-theme-vscode-extension/blob/master/docs/INSTALLATION.md).",
            "media": {
              "image": "assets/dashboard-tab-installation.png",
              "altText": "AristoByte dashboard installation tab"
            }
          },
          {
            "id": "aristobyte.customization",
            "title": "Customization Tab",
            "description": "Tune your editor with [`docs/CUSTOMIZATION.md`](https://github.com/aristobyte/aristo-theme-vscode-extension/blob/master/docs/CUSTOMIZATION.md).",
            "media": {
              "image": "assets/dashboard-tab-customization.png",
              "altText": "AristoByte dashboard customization tab"
            }
          },
          {
            "id": "aristobyte.accessibility",
            "title": "Accessibility Tab",
            "description": "Read accessibility guidance in [`docs/ACCESSIBILITY.md`](https://github.com/aristobyte/aristo-theme-vscode-extension/blob/master/docs/ACCESSIBILITY.md).",
            "media": {
              "image": "assets/dashboard-tab-accessibility.png",
              "altText": "AristoByte dashboard accessibility tab"
            }
          },
          {
            "id": "aristobyte.troubleshooting",
            "title": "Troubleshooting Tab",
            "description": "Fix common issues using [`docs/TROUBLESHOOTING.md`](https://github.com/aristobyte/aristo-theme-vscode-extension/blob/master/docs/TROUBLESHOOTING.md).",
            "media": {
              "image": "assets/dashboard-tab-troubleshooting.png",
              "altText": "AristoByte dashboard troubleshooting tab"
            }
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "aristobyteTheme.openHome",
        "title": "AristoByte: Open Home",
        "category": "AristoByte"
      },
      {
        "command": "aristobyteTheme.openDashboard",
        "title": "AristoByte: Open Getting Started Dashboard",
        "category": "AristoByte"
      },
      {
        "command": "aristobyteTheme.openDocsIndex",
        "title": "AristoByte: Open Documentation Index",
        "category": "AristoByte"
      },
      {
        "command": "aristobyteTheme.openMarketplacePage",
        "title": "AristoByte: Open Marketplace/Homepage",
        "category": "AristoByte"
      },
      {
        "command": "aristobyteTheme.applyDarkTheme",
        "title": "AristoByte: Apply Dark Theme",
        "category": "AristoByte"
      },
      {
        "command": "aristobyteTheme.applyLightTheme",
        "title": "AristoByte: Apply Light Theme",
        "category": "AristoByte"
      },
      {
        "command": "aristobyteTheme.applyMidnightTheme",
        "title": "AristoByte: Apply Midnight Theme",
        "category": "AristoByte"
      },
      {
        "command": "aristobyteTheme.applyDuskTheme",
        "title": "AristoByte: Apply Dusk Theme",
        "category": "AristoByte"
      },
      {
        "command": "aristobyteTheme.applyHighContrastDarkTheme",
        "title": "AristoByte: Apply High Contrast Dark Theme",
        "category": "AristoByte"
      },
      {
        "command": "aristobyteTheme.applyHighContrastLightTheme",
        "title": "AristoByte: Apply High Contrast Light Theme",
        "category": "AristoByte"
      },
      {
        "command": "aristobyteTheme.applyOledTheme",
        "title": "AristoByte: Apply OLED Theme",
        "category": "AristoByte"
      },
      {
        "command": "aristobyteTheme.applySoftLightTheme",
        "title": "AristoByte: Apply Soft Light Theme",
        "category": "AristoByte"
      }
    ],
    "configuration": {
      "title": "AristoByte Theme",
      "properties": {
        "aristobyteTheme.showWalkthroughOnInstallOrUpdate": {
          "type": "boolean",
          "default": true,
          "description": "Open the AristoByte Getting Started dashboard after install/update."
        },
        "aristobyteTheme.postInstallExperience": {
          "type": "string",
          "enum": [
            "home",
            "walkthrough",
            "none"
          ],
          "default": "home",
          "markdownDescription": "Post-install/update surface: `home` opens the rich AristoByte webview, `walkthrough` opens VS Code walkthrough, `none` disables automatic opening."
        },
        "aristobyteTheme.defaultThemeOnInstall": {
          "type": "string",
          "enum": [
            "auto",
            "dark",
            "midnight",
            "dusk",
            "highContrastDark",
            "oled",
            "light",
            "softLight",
            "highContrastLight"
          ],
          "default": "auto",
          "markdownDescription": "Default theme to apply on first install. `auto` keeps your current theme unchanged. Available values: `dark`, `midnight`, `dusk`, `highContrastDark`, `oled`, `light`, `softLight`, `highContrastLight`."
        },
        "aristobyteTheme.openDocsInEditor": {
          "type": "boolean",
          "default": true,
          "description": "Open AristoByte docs inside VS Code editor tabs when available."
        }
      }
    }
  },
  "main": "./extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onCommand:aristobyteTheme.openHome",
    "onCommand:aristobyteTheme.openDashboard",
    "onCommand:aristobyteTheme.openDocsIndex",
    "onCommand:aristobyteTheme.openMarketplacePage",
    "onCommand:aristobyteTheme.applyDarkTheme",
    "onCommand:aristobyteTheme.applyLightTheme",
    "onCommand:aristobyteTheme.applyMidnightTheme",
    "onCommand:aristobyteTheme.applyDuskTheme",
    "onCommand:aristobyteTheme.applyHighContrastDarkTheme",
    "onCommand:aristobyteTheme.applyHighContrastLightTheme",
    "onCommand:aristobyteTheme.applyOledTheme",
    "onCommand:aristobyteTheme.applySoftLightTheme"
  ],
  "markdown": "github",
  "extensionKind": [
    "ui"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    },
    "virtualWorkspaces": {
      "supported": true
    }
  }
}
